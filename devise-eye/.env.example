# Devise Desktop Agent Environment Variables
# Copy this file to .env and configure for your environment

# Backend API URL (optional - can also be set in config.json)
# Format: https://your-api-domain.com or http://localhost:3000/api
DEVISE_BACKEND_URL=https://api.devise.example.com

# Alternative: Set the full API URL directly
# DEVISE_API_URL=http://localhost:3000/api

# Dashboard URL (for setup instructions)
# DEVISE_DASHBOARD_URL=http://localhost:8081

# Organization ID (required)
# DEVISE_ORG_ID=your-org-id

# Device API Key (required)
# DEVISE_API_KEY=your-api-key

# Firebase Project ID (optional - for Firestore)
# DEVISE_FIREBASE_PROJECT_ID=your-firebase-project

# Service Account Path (optional - for Firestore auth)
# DEVISE_SERVICE_ACCOUNT_PATH=C:\ProgramData\Devise\service_account.json

# DNS-over-HTTPS (optional - set to true to enable)
# DEVISE_DOH_ENABLED=false
