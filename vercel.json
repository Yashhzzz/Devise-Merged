{
  "cleanUrls": true,
  "builds": [
    {
      "src": "devise-iris/frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/server.py" },
    { "src": "/(.*)", "dest": "/devise-iris/frontend/dist/index.html" }
  ]
}
